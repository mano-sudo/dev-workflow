# Build output — dist/ IS committed so `git clone` gives a ready-to-run
# extension without needing TypeScript. Rebuild with `npm run build`.
*.tsbuildinfo

# Generated reports
dev-workflow-reports/
*.pdf
*.docx
!templates/**/*.pdf
# Keep the blank example PDFs that ship as design references
!samples/*.pdf

# Packed npm tarball
*.tgz

# Local runtime storage (regenerated at runtime; keep committed empty seeds only)
storage/*.json
!storage/session.json
!storage/completed.json

# Environment / secrets
.env
.env.local
.env.*.local

